{
    "dashboard": {
        "title": "Message Wall",
        "tags": [
            "app",
            "demo"
        ],
        "timezone": "browser",
        "refresh": "5s",
        "time": {
            "from": "now-15m",
            "to": "now"
        },
        "panels": [
            {
                "title": "Messages in database",
                "type": "stat",
                "gridPos": {
                    "h": 6,
                    "w": 6,
                    "x": 0,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "app_messages_count",
                        "legendFormat": "messages"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "thresholds": {
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 50
                                },
                                {
                                    "color": "red",
                                    "value": 100
                                }
                            ]
                        }
                    }
                }
            },
            {
                "title": "Messages posted (total)",
                "type": "stat",
                "gridPos": {
                    "h": 6,
                    "w": 6,
                    "x": 6,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "app_messages_posted_total",
                        "legendFormat": "posted"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "fixed",
                            "fixedColor": "blue"
                        }
                    }
                }
            },
            {
                "title": "Requests / sec",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "rate(app_http_request_duration_seconds_count[1m])",
                        "legendFormat": "{{method}} {{path}}"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "reqps"
                    }
                }
            },
            {
                "title": "Posts / min",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 6
                },
                "targets": [
                    {
                        "expr": "rate(app_messages_posted_total[1m]) * 60",
                        "legendFormat": "posts/min"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "fixed",
                            "fixedColor": "purple"
                        }
                    }
                }
            },
            {
                "title": "Response time (p95)",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 8
                },
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, rate(app_http_request_duration_seconds_bucket[1m]))",
                        "legendFormat": "p95 {{method}} {{path}}"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "s"
                    }
                }
            },
            {
                "title": "Memory usage",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 14
                },
                "targets": [
                    {
                        "expr": "process_resident_memory_bytes",
                        "legendFormat": "RSS"
                    },
                    {
                        "expr": "nodejs_heap_size_used_bytes",
                        "legendFormat": "Heap used"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "bytes"
                    }
                }
            },
            {
                "title": "Event loop lag (p99)",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "nodejs_eventloop_lag_p99_seconds",
                        "legendFormat": "p99 lag"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "s"
                    }
                }
            }
        ],
        "schemaVersion": 39
    },
    "overwrite": true
}