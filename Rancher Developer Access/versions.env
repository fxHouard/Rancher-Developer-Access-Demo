# ═══════════════════════════════════════════════════════════════
# Public Image Versions — single source of truth
#
# All public (upstream) image tags used in the shadow demo.
# Edit these values to pin or upgrade public images.
#
# For Keycloak (no Helm chart), this also controls the AppCo
# container image tag since Tilt deploys it directly.
# ═══════════════════════════════════════════════════════════════

# --- Database ---
POSTGRES_TAG=18

# --- Monitoring ---
PROMETHEUS_TAG=v3.11.2
GRAFANA_TAG=12.4.2

# --- Identity ---
KEYCLOAK_TAG=26.5.7

# --- App runtime ---
NODE_TAG=24

# --- Security scanner ---
TRIVY_TAG=0.69.3
# AppCo trivy includes a SUSE patch suffix (e.g. -9.1)
# This cannot be derived from the public tag automatically.
# To find the latest: check dp.apps.rancher.io/containers/trivy tags
APPCO_TRIVY_TAG=0.69.3-10.4
